---
layout: base.njk
title: "Contact — Harry Wellbelove"
description: "Contact Harry Wellbelove."
permalink: /contact/
extraJs: |
  <script>
  document.getElementById('contact-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn=document.getElementById('submit-btn');
    const txt=document.getElementById('submit-text');
    const success=document.getElementById('form-success');
    const error=document.getElementById('form-error');
    success.style.display='none'; error.style.display='none';
    btn.disabled=true; txt.textContent='Sending...';
    try {
      const res=await fetch('https://formspree.io/f/mlgopaqa',{
        method:'POST',body:new FormData(this),headers:{'Accept':'application/json'}
      });
      if(res.ok){success.style.display='block';this.reset();txt.textContent='Sent ✓';}
      else throw new Error();
    } catch{error.style.display='block';btn.disabled=false;txt.textContent='Send message →';}
  });
  </script>
---

<main>
<div class="wrap page-content">

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;">

    <div class="fade-in">
      <div class="label">Contact</div>
      <h1 class="display-lg" style="margin-bottom:24px;line-height:1.05;">
        If you've got<br>something worth<br><em class="accent">talking about.</em>
      </h1>
      <p style="font-size:15px;color:var(--muted);line-height:1.8;margin-bottom:40px;">
        Get in touch via the form or reach out directly.
        I try to respond to everything.
      </p>
      <div style="display:flex;flex-direction:column;gap:16px;">
        <a class="link" href="mailto:harry@wellbelove.org" style="font-size:12px;">
          <span class="link-arr">→</span> harry@wellbelove.org
        </a>
        <a class="link" href="https://linkedin.com/in/harrywellbelove" target="_blank" rel="noopener" style="font-size:12px;">
          <span class="link-arr">↗</span> linkedin.com/in/harrywellbelove
        </a>
        <a class="link" href="https://github.com/wblv-dev" target="_blank" rel="noopener" style="font-size:12px;">
          <span class="link-arr">↗</span> github.com/wblv-dev
        </a>
      </div>
    </div>

    <div class="card fade-in-2" style="padding:36px;">
      <form id="contact-form">
        <div class="form-group">
          <label class="form-label" for="name">Name</label>
          <input class="form-input" type="text" id="name" name="name"
            placeholder="Your name" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email"
            placeholder="your@email.com" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label class="form-label" for="message">Message</label>
          <textarea class="form-textarea" id="message" name="message"
            placeholder="What's on your mind..." required></textarea>
        </div>
        <button class="btn btn-primary" type="submit" id="submit-btn" style="width:100%;justify-content:center;">
          <span id="submit-text">Send message →</span>
        </button>
        <div class="form-success" id="form-success">Message sent — I'll get back to you.</div>
        <div class="form-error" id="form-error">Something went wrong. Try emailing harry@wellbelove.org directly.</div>
      </form>
    </div>

  </div>

</div>
</main>
