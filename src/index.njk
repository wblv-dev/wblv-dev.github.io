---
layout: base.njk
title: Harry Wellbelove
description: "Harry Wellbelove — Cyber Security Professional. SC Cleared. Milton Keynes, UK."
robots: "index, follow"
---

<main style="display:flex;flex-direction:column;">
<div class="wrap page-content" style="padding-top:calc(var(--nav-h) + 24px);padding-bottom:16px;flex:1;display:flex;flex-direction:column;gap:12px;">

  <section class="section fade-in" style="margin-bottom:0;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:32px;margin-bottom:20px;">
      <h1 class="display-xl" style="color:var(--ink)">
        Harry<br><em class="accent">Wellbelove</em>
      </h1>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:12px;flex-shrink:0;padding-top:8px;">
        <a class="link" href="https://linkedin.com/in/harrywellbelove" target="_blank" rel="noopener">
          <span class="link-arr">↗</span> LinkedIn
        </a>
        <a class="link" href="https://github.com/wblv-dev" target="_blank" rel="noopener">
          <span class="link-arr">↗</span> GitHub
        </a>
        <a class="link" href="mailto:harry@wellbelove.org">
          <span class="link-arr">↗</span> harry@wellbelove.org
        </a>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:20px;margin-top:8px;">
      <span style="font-size:14px;color:var(--muted);">Cyber Security Professional</span>
      <span class="tag tag-accent">SC Cleared</span>
      <span class="tag tag-dim">Milton Keynes, UK</span>
    </div>

    <p class="italic-statement" style="font-size:clamp(17px,2vw,22px);margin-bottom:20px;">
      Five years in cyber security — operations, engineering &amp;
      leadership. Driven by protecting systems that genuinely matter.
    </p>

  </section>

    <!-- Stats row -->
    <div class="fade-in-2" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:1px;background:var(--rule);border:1px solid var(--rule);border-radius:var(--radius-lg);overflow:hidden;">
      <div style="padding:16px;background:var(--s1);display:flex;flex-direction:column;justify-content:center;min-height:72px;">
        <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--accent);line-height:1;margin-bottom:4px;">{{ stats.yearsInSecurity }}y</div>
        <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">In security</div>
      </div>
      <div style="padding:16px;background:var(--s1);display:flex;flex-direction:column;justify-content:center;min-height:72px;">
        <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--accent);line-height:1;margin-bottom:4px;">{{ github.publicRepos }}</div>
        <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">Public repos</div>
      </div>
      <div style="padding:16px;background:var(--s1);display:flex;flex-direction:column;justify-content:center;min-height:72px;">
        <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--accent);line-height:1;margin-bottom:4px;">{{ collections.posts.length }}</div>
        <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">Blog posts</div>
      </div>
      <div style="padding:16px;background:var(--s1);display:flex;flex-direction:column;justify-content:center;min-height:72px;">
        <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--accent);line-height:1;margin-bottom:4px;">{{ stats.certifications }}</div>
        <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">Certifications</div>
      </div>
    </div>

    <!-- "Currently working on" panel: 13-week grid + summary stats -->
    <div class="fade-in-2" style="padding:18px 20px;background:var(--s1);border:1px solid var(--rule);border-radius:var(--radius-lg);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
        <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">Currently working on · {{ github.rangeLabel }}</div>
        <div style="display:flex;align-items:center;gap:4px;font-family:var(--font-mono);font-size:9px;letter-spacing:0.08em;color:var(--dim);text-transform:uppercase;">
          <span>less</span>
          <span style="width:9px;height:9px;border-radius:2px;background:var(--s2);"></span>
          <span style="width:9px;height:9px;border-radius:2px;background:var(--accent);opacity:0.35;"></span>
          <span style="width:9px;height:9px;border-radius:2px;background:var(--accent);opacity:0.65;"></span>
          <span style="width:9px;height:9px;border-radius:2px;background:var(--accent);"></span>
          <span>more</span>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:28px;flex-wrap:wrap;">
        <!-- Contribution grid -->
        <div style="display:grid;grid-template-columns:repeat(13,16px);gap:3px;flex-shrink:0;">
          {% for week in github.contributions %}
          <div style="display:grid;grid-template-rows:repeat(7,16px);gap:3px;">
            {% for day in week %}
            {%- if day.future %}{% set bg = 'transparent' %}{% set op = '0' %}
            {%- elif day.count == 0 %}{% set bg = 'var(--s2)' %}{% set op = '1' %}
            {%- elif day.count < 3 %}{% set bg = 'var(--accent)' %}{% set op = '0.35' %}
            {%- elif day.count < 6 %}{% set bg = 'var(--accent)' %}{% set op = '0.65' %}
            {%- else %}{% set bg = 'var(--accent)' %}{% set op = '1' %}{% endif %}
            <div title="{{ day.date }}: {{ day.count }} commits" style="border-radius:2px;background:{{ bg }};opacity:{{ op }};"></div>
            {% endfor %}
          </div>
          {% endfor %}
        </div>
        <!-- Summary stats inline -->
        <div style="display:flex;align-items:center;gap:28px;flex-wrap:wrap;">
          <div>
            <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--accent);line-height:1;margin-bottom:4px;">{{ github.totalCommits }}</div>
            <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">Commits (90d)</div>
          </div>
          <div>
            <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--accent);line-height:1;margin-bottom:4px;">{{ github.activeDays }}</div>
            <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">Active days</div>
          </div>
          <div>
            <div style="font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--ink);line-height:1.1;margin-bottom:4px;">{{ github.lastActivityLabel }}</div>
            <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">Last push</div>
          </div>
          <div style="min-width:0;">
            <div style="font-family:var(--font-mono);font-size:12px;font-weight:500;color:var(--ink);line-height:1.2;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ github.currentRepo or '—' }}</div>
            <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.12em;color:var(--dim);text-transform:uppercase;">Most recent repo</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent repos -->
    <div class="fade-in-2" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;">
      {% for repo in github.recent %}
      <a href="{{ repo.docs or repo.url }}"{% if not repo.docs %} target="_blank" rel="noopener"{% endif %} style="text-decoration:none;padding:12px 14px;background:var(--s1);border:1px solid var(--rule);border-radius:var(--radius-lg);transition:border-color 0.15s, background 0.15s;display:flex;flex-direction:column;gap:8px;" onmouseover="this.style.borderColor='var(--accent)';this.style.background='var(--s2)'" onmouseout="this.style.borderColor='var(--rule)';this.style.background='var(--s1)'">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;">
          <div style="font-family:var(--font-mono);font-size:11px;font-weight:500;color:var(--ink);overflow:hidden;text-overflow:ellipsis;">{{ repo.name }}</div>
          {% if repo.stars > 0 %}<div style="font-family:var(--font-mono);font-size:10px;color:var(--dim);flex-shrink:0;">★ {{ repo.stars }}</div>{% endif %}
        </div>
        <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;color:var(--accent);text-transform:uppercase;">View {{ 'project' if repo.docs else 'on GitHub' }} →</div>
      </a>
      {% endfor %}
    </div>

  <section class="section fade-in-3" style="margin-top:auto;margin-bottom:0;display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap;padding:24px 28px;background:var(--s1);border:1px solid var(--rule);border-radius:var(--radius-lg);">
    <div>
      <div style="font-family:var(--font-display);font-size:20px;font-weight:700;margin-bottom:6px;">
        If you've got something worth <em class="accent">talking about.</em>
      </div>
      <div style="font-size:13px;color:var(--muted);">Get in touch directly or via the contact page.</div>
    </div>
    <a class="btn btn-outline" href="/contact/">Get in touch →</a>
  </section>

</div>
</main>
