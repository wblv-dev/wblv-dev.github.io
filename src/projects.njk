---
layout: base.njk
title: "Projects — Harry Wellbelove"
description: "Projects — Harry Wellbelove."
permalink: /projects/
---

<main style="display:flex;flex-direction:column;">
<div class="wrap page-content" style="padding-top:calc(var(--nav-h) + 48px);padding-bottom:16px;flex:1;display:flex;flex-direction:column;">

  <section class="section fade-in" style="margin-bottom:40px;">
    <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.18em;color:var(--dim);text-transform:uppercase;margin-bottom:16px;">Projects</div>
    <h1 class="display-lg" style="margin-bottom:20px;">
      Things I've <em class="accent">built.</em>
    </h1>
    <p style="font-size:15px;color:var(--muted);line-height:1.7;">
      Personal projects, open source tooling, and infrastructure work.
      Solving real problems, documented to be useful to others.
    </p>
  </section>

  {# Gather unique genres from docs collection, sorted alphabetically #}
  {%- set genres = [] %}
  {%- for doc in collections.docs %}
    {%- set g = doc.data.genre or "Other" %}
    {%- if g not in genres %}{% set genres = (genres.push(g), genres) %}{% endif %}
  {%- endfor %}
  {%- set genres = genres | sort %}

  <section class="section fade-in-2" style="margin-bottom:40px;display:grid;gap:32px;">
    {%- for g in genres %}
      {%- set groupDocs = [] %}
      {%- for doc in collections.docs %}
        {%- if (doc.data.genre or "Other") == g %}{% set groupDocs = (groupDocs.push(doc), groupDocs) %}{% endif %}
      {%- endfor %}
      {%- set groupDocs = groupDocs | sort(false, false, "data.order") %}
    <div>
      <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.18em;color:var(--dim);text-transform:uppercase;margin-bottom:14px;">{{ g }}</div>
      <div style="display:grid;gap:12px;grid-auto-rows:1fr;">
        {%- for doc in groupDocs %}
          {%- set titleShort = doc.data.title | replace(" — Harry Wellbelove", "") %}
          {%- set repoName = (doc.data.github_url or "") | replace("https://github.com/wblv-dev/", "") | lower %}
          {%- set meta = github.projectMeta[repoName] %}
        <a href="{{ doc.url }}" style="text-decoration:none;display:block;padding:22px 26px;background:var(--s1);border:1px solid var(--rule);border-radius:var(--radius-lg);transition:border-color 0.15s, background 0.15s;min-height:150px;" onmouseover="this.style.borderColor='var(--accent)';this.style.background='var(--s2)'" onmouseout="this.style.borderColor='var(--rule)';this.style.background='var(--s1)'">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:16px;">
            <div style="min-width:0;">
              <div style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--ink);line-height:1.2;margin-bottom:10px;">{{ titleShort }}</div>
              {%- if doc.data.summary %}
              <p style="font-size:14px;color:var(--muted);line-height:1.7;margin:0;">{{ doc.data.summary }}</p>
              {%- endif %}
            </div>
            <span style="font-family:var(--font-mono);font-size:14px;color:var(--dim);flex-shrink:0;line-height:1;padding-top:4px;">↗</span>
          </div>
          {%- if meta %}
          <div style="display:flex;align-items:center;gap:18px;margin-top:14px;padding-top:14px;border-top:1px solid var(--rule);font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;color:var(--dim);text-transform:uppercase;">
            <span>Updated {{ meta.pushedRelative }}</span>
            {%- if meta.stars > 0 %}
            <span>★ {{ meta.stars }}</span>
            {%- endif %}
            <span style="margin-left:auto;color:var(--dim);">{{ repoName }}</span>
          </div>
          {%- endif %}
        </a>
        {%- endfor %}
      </div>
    </div>
    {%- endfor %}
  </section>

  <section class="section fade-in-3" style="margin-top:auto;margin-bottom:0;display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap;padding:24px 28px;background:var(--s1);border:1px solid var(--rule);border-radius:var(--radius-lg);">
    <div>
      <div style="font-family:var(--font-display);font-size:20px;font-weight:700;margin-bottom:6px;">
        If you've got something worth <em class="accent">talking about.</em>
      </div>
      <div style="font-size:13px;color:var(--muted);">Get in touch directly or via the contact page.</div>
    </div>
    <a class="btn btn-outline" href="/contact/">Get in touch →</a>
  </section>

</div>
</main>
