<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="{{ description | default(site.description) }}">
<meta name="robots" content="noindex">
<title>{{ title }}</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/style.css?v=2026-04-05-c">
<link rel="stylesheet" href="/assets/css/docs.css?v=2026-04-05-c">
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-mark" href="/">wblv-dev</a>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/about/">About</a></li>
      <li><a href="/projects/">Projects</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
  </div>
</nav>

{%- set currentGenre = genre or "Other" %}
{%- set titleShort = title | replace(" — Harry Wellbelove", "") %}

<div class="docs-layout">
  <aside class="docs-sidebar">
    <a href="/projects/" class="docs-back-link">
      <span class="docs-back-arrow">←</span> All projects
    </a>
    <div class="docs-search">
      <input type="text" class="docs-search-input" placeholder="Search sections..." aria-label="Search sections">
    </div>
    <div class="docs-sidebar-header">
      <div class="docs-sidebar-genre">{{ currentGenre }}</div>
      <div class="docs-sidebar-title">{{ titleShort }}</div>
    </div>
    <nav class="docs-nav" id="docs-nav">
      <ul class="docs-nav-sections" id="docs-nav-sections">
        <!-- Populated by docs.js with h2 headings from current page -->
      </ul>
    </nav>
  </aside>

  <main class="docs-content">
    {# Breadcrumbs #}
    <nav class="docs-breadcrumbs" aria-label="Breadcrumb">
      <a href="/projects/">Projects</a>
      <span class="docs-breadcrumb-sep">/</span>
      <span class="docs-breadcrumb-current">{{ titleShort }}</span>
    </nav>

    {# Genre badge + title #}
    <div class="docs-header">
      <span class="tag tag-dim">{{ currentGenre }}</span>
    </div>
    <h1 class="docs-title">{{ titleShort }}</h1>

    {%- if github_url %}
    <div class="docs-source-link">
      <a href="{{ github_url }}" target="_blank" rel="noopener">↗ View Source on GitHub</a>
    </div>
    {%- endif %}

    {{ content | safe }}

  </main>
  <footer class="docs-footer">
    <div class="docs-footer-inner">
      <div class="docs-footer-left">&copy; 2026 Harry Wellbelove &middot; wellbelove.org</div>
      <a class="docs-footer-gh" href="https://github.com/wblv-dev" target="_blank" rel="noopener">GitHub ↗</a>
    </div>
  </footer>
</div>

<script src="/assets/js/nav.js"></script>
<script src="/assets/js/docs.js"></script>
</body>
</html>
