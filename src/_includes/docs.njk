<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="{{ description | default(site.description) }}">
<meta name="robots" content="noindex">
<title>{{ title }}</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/style.css">
<link rel="stylesheet" href="/assets/css/docs.css">
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-mark" href="/">wblv-dev</a>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/about/">About</a></li>
      <li><a href="/projects/">Projects</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
  </div>
</nav>

{# Build the full sorted, genre-grouped list of docs once #}
{%- set allDocs = collections.docs %}
{%- set genres = [] %}
{%- for doc in allDocs %}
  {%- set g = doc.data.genre or "Other" %}
  {%- if g not in genres %}{% set genres = (genres.push(g), genres) %}{% endif %}
{%- endfor %}
{%- set genres = genres | sort %}

{# Flat ordered list (for prev/next) built in the same iteration order used in the sidebar #}
{%- set orderedDocs = [] %}
{%- for g in genres %}
  {%- set groupDocs = [] %}
  {%- for doc in allDocs %}
    {%- if (doc.data.genre or "Other") == g %}{% set groupDocs = (groupDocs.push(doc), groupDocs) %}{% endif %}
  {%- endfor %}
  {%- set groupDocs = groupDocs | sort(false, false, "data.order") %}
  {%- for doc in groupDocs %}{% set orderedDocs = (orderedDocs.push(doc), orderedDocs) %}{% endfor %}
{%- endfor %}

{# Find current page index for prev/next #}
{%- set currentIdx = -1 %}
{%- for doc in orderedDocs %}
  {%- if doc.url == page.url %}{% set currentIdx = loop.index0 %}{% endif %}
{%- endfor %}
{%- set prevDoc = orderedDocs[currentIdx - 1] if currentIdx > 0 else null %}
{%- set nextDoc = orderedDocs[currentIdx + 1] if currentIdx < (orderedDocs.length - 1) else null %}

{%- set currentDoc = orderedDocs[currentIdx] if currentIdx >= 0 else null %}
{%- set currentGenre = currentDoc.data.genre if currentDoc else "Other" %}
{%- set titleShort = title | replace(" — Harry Wellbelove", "") %}

<div class="docs-layout">
  <aside class="docs-sidebar">
    <div class="docs-search">
      <input type="text" class="docs-search-input" placeholder="Search docs..." aria-label="Search docs">
    </div>
    <nav class="docs-nav" id="docs-nav">
      {%- for g in genres %}
      <div class="docs-nav-group" data-genre="{{ g }}">
        <button class="docs-nav-heading" aria-expanded="true">
          <span>{{ g }}</span>
          <svg class="docs-nav-chevron" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <ul class="docs-nav-items">
          {%- set groupDocs = [] %}
          {%- for doc in allDocs %}
            {%- if (doc.data.genre or "Other") == g %}{% set groupDocs = (groupDocs.push(doc), groupDocs) %}{% endif %}
          {%- endfor %}
          {%- set groupDocs = groupDocs | sort(false, false, "data.order") %}
          {%- for doc in groupDocs %}
            {%- set pageTitleShort = doc.data.title | replace(" — Harry Wellbelove", "") %}
            {%- set isActive = doc.url == page.url %}
          <li class="docs-nav-page-wrap{% if isActive %} active{% endif %}">
            <a href="{{ doc.url }}" class="docs-nav-page{% if isActive %} active{% endif %}" data-title="{{ pageTitleShort }}">{{ pageTitleShort }}</a>
            {%- if isActive %}
            <ul class="docs-nav-sections" id="docs-nav-sections">
              <!-- Populated by docs.js with h2 headings from current page -->
            </ul>
            {%- endif %}
          </li>
          {%- endfor %}
        </ul>
      </div>
      {%- endfor %}
    </nav>
  </aside>

  <main class="docs-content">
    {# Breadcrumbs #}
    <nav class="docs-breadcrumbs" aria-label="Breadcrumb">
      <a href="/projects/">Projects</a>
      <span class="docs-breadcrumb-sep">/</span>
      <span class="docs-breadcrumb-current">{{ titleShort }}</span>
    </nav>

    {# Genre badge + title #}
    <div class="docs-header">
      <span class="tag tag-dim">{{ currentGenre }}</span>
    </div>
    <h1 class="docs-title">{{ titleShort }}</h1>

    {{ content | safe }}

    {# Prev / Next nav #}
    {%- if prevDoc or nextDoc %}
    <nav class="docs-pagination" aria-label="Docs navigation">
      {%- if prevDoc %}
      <a href="{{ prevDoc.url }}" class="docs-pagination-link docs-pagination-prev">
        <span class="docs-pagination-arrow">←</span>
        <span class="docs-pagination-inner">
          <span class="docs-pagination-label">Previous</span>
          <span class="docs-pagination-title">{{ prevDoc.data.title | replace(" — Harry Wellbelove", "") }}</span>
        </span>
      </a>
      {%- else %}<span></span>{%- endif %}
      {%- if nextDoc %}
      <a href="{{ nextDoc.url }}" class="docs-pagination-link docs-pagination-next">
        <span class="docs-pagination-inner">
          <span class="docs-pagination-label">Next</span>
          <span class="docs-pagination-title">{{ nextDoc.data.title | replace(" — Harry Wellbelove", "") }}</span>
        </span>
        <span class="docs-pagination-arrow">→</span>
      </a>
      {%- else %}<span></span>{%- endif %}
    </nav>
    {%- endif %}

    {%- if github_url %}
    <div class="project-links">
      <a class="btn btn-outline" href="{{ github_url }}" target="_blank" rel="noopener">
        ↗ View on GitHub
      </a>
    </div>
    {%- endif %}
  </main>
  <footer class="docs-footer">
    <div class="docs-footer-inner">
      <div class="docs-footer-left">&copy; 2026 Harry Wellbelove &middot; wellbelove.org</div>
      <div class="docs-footer-right">
        <a href="/about/">About</a>
        <a href="/projects/">Projects</a>
        <a href="/contact/">Contact</a>
        <a href="https://github.com/wblv-dev" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </footer>
</div>

<script src="/assets/js/nav.js"></script>
<script src="/assets/js/docs.js"></script>
</body>
</html>
