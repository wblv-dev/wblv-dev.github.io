<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="{{ description | default(site.description) }}">
{%- if robots %}
<meta name="robots" content="{{ robots }}">
{%- endif %}
<title>{{ title }}</title>
<meta property="og:site_name" content="wellbelove.org">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description | default(site.description) }}">
<meta property="og:url" content="https://wellbelove.org{{ page.url }}">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ description | default(site.description) }}">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/style.css?v=2026-04-05-e">
{%- if extraCss %}
<link rel="stylesheet" href="{{ extraCss }}">
{%- endif %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-mark" href="/">wblv-dev</a>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/about/">About</a></li>
      <li><a href="/projects/">Projects</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
  </div>
</nav>

{{ content | safe }}

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">&copy; 2026 Harry Wellbelove &middot; wellbelove.org</div>
    <a class="footer-gh" href="https://github.com/wblv-dev" target="_blank" rel="noopener">GitHub ↗</a>
  </div>
</footer>

<script src="/assets/js/nav.js"></script>
{%- if extraJs %}
{{ extraJs | safe }}
{%- endif %}
</body>
</html>
